{
  "name": "zero-token",
  "version": "2026.4.1",
  "description": "Standalone Zero Token plugin for OpenClaw browser-authenticated web providers",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "node ./build.mjs"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "0.57.1",
    "@mariozechner/pi-ai": "0.57.1",
    "json5": "2.2.3",
    "playwright-core": "1.58.2",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "esbuild": "0.25.9"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "localPath": ".",
      "defaultChoice": "local"
    }
  }
}
