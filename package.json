{
  "name": "zero-token",
  "version": "2026.4.1",
  "description": "Standalone Zero Token plugin for OpenClaw browser-authenticated web providers",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "node ./build.mjs",
    "mac": "node ./Zero-Token-mac.mjs"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "0.71.1",
    "@mariozechner/pi-ai": "0.71.1",
    "json5": "2.2.3",
    "playwright-core": "1.58.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "esbuild": "0.25.9"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "providers": [
      "chatgpt-web",
      "claude-web",
      "deepseek-web",
      "doubao-web",
      "gemini-web",
      "glm-intl-web",
      "glm-web",
      "grok-web",
      "kimi-web",
      "perplexity-web",
      "qwen-cn-web",
      "qwen-web"
    ],
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.3",
      "minGatewayVersion": "2026.5.3"
    },
    "build": {
      "openclawVersion": "2026.5.3",
      "pluginSdkVersion": "2026.5.3"
    },
    "install": {
      "localPath": ".",
      "defaultChoice": "local"
    }
  }
}
